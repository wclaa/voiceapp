<?xml version="1.0" encoding="utf-8"?>
<!-- 语音记账按钮：主紫色渐变 + 22dp圆角 + 微光晕 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外发光 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorPrimaryGlow" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- 主按钮 -->
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#C084FC"
                android:endColor="@color/colorPrimary"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="@dimen/voice_btn_radius" />
        </shape>
    </item>
</layer-list>