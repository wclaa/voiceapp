<!-- 手动记账弹窗 - 深紫磨砂玻璃风格，与首页100%统一 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none"
    android:background="@drawable/bg_dialog">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp">

        <!-- 模块1：顶部标题区 -->
        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="记一笔"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="20dp" />

        <!-- 模块2：金额输入区（核心，视觉权重最高） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¥"
                android:textSize="32sp"
                android:textColor="@color/textSecondary"
                android:layout_marginEnd="4dp" />

            <EditText
                android:id="@+id/et_amount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:gravity="center"
                android:hint="0.00"
                android:textColorHint="@color/textTertiary"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_input_field"
                android:maxLength="12"
                android:selectAllOnFocus="true"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- 模块3：收支类型切换（胶囊分段控件） -->
        <LinearLayout
            android:id="@+id/ll_type_segment"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_segment_bg"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tv_segment_expense"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="支出"
                android:textSize="14sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tv_segment_income"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="收入"
                android:textSize="14sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- 模块4：分类选择区（横向滚动标签栏） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="分类"
                android:textSize="13sp"
                android:textColor="@color/textSecondary"
                android:layout_marginEnd="12dp" />

            <HorizontalScrollView
                android:id="@+id/hsv_category"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/ll_category_tags"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />
            </HorizontalScrollView>
        </LinearLayout>

        <!-- 模块5：日期选择行 -->
        <LinearLayout
            android:id="@+id/ll_date_row"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_field"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="日期"
                android:textSize="13sp"
                android:textColor="@color/textSecondary" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026-06-29"
                android:textSize="14sp"
                android:textColor="@color/textPrimary" />

            <TextView
                android:layout_width="20dp"
                android:layout_height="match_parent"
                android:text="›"
                android:textSize="16sp"
                android:textColor="@color/textTertiary"
                android:gravity="center" />
        </LinearLayout>

        <!-- 模块6：备注输入区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="备注"
                android:textSize="13sp"
                android:textColor="@color/textSecondary"
                android:layout_marginEnd="12dp" />

            <EditText
                android:id="@+id/et_remark"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_field"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="14sp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textTertiary"
                android:hint="添加备注（可选）"
                android:inputType="text"
                android:maxLength="50"
                android:singleLine="true"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- 模块7：底部操作按钮区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:text="取消"
                android:textSize="15sp"
                android:textColor="@color/textSecondary"
                android:gravity="center"
                android:background="@drawable/bg_input_field"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:layout_width="16dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="3"
                android:text="保存"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:background="@drawable/bg_voice_btn"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>