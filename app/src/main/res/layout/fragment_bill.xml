<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".fragment.BillFragment">

    <!-- 顶部月度汇总栏（毛玻璃样式） -->
    <LinearLayout
        android:id="@+id/ll_monthly_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_glass_card"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginVertical="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_bill_month_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="7月账单"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tv_bill_total_expense"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="总支出 ¥10.00"
            android:textSize="16sp"
            android:textColor="#F87171" />

        <!-- 搜索按钮 -->
        <ImageView
            android:id="@+id/iv_bill_search"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="12dp"
            android:src="@android:drawable/ic_menu_search"
            android:tint="#C8BDE6"
            android:contentDescription="搜索" />

        <!-- 过滤按钮 -->
        <ImageView
            android:id="@+id/iv_bill_filter"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="10dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="#C8BDE6"
            android:contentDescription="过滤" />

    </LinearLayout>

    <!-- 账单列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_bill_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_monthly_summary" />

    <!-- 空状态提示 -->
    <TextView
        android:id="@+id/tv_empty_bill_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="暂无账单记录"
        android:textSize="13sp"
        android:textColor="#8E82B5"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>