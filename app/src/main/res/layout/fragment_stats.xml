<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true"
    android:scrollbars="none"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- 顶部安全区 -->
        <View android:layout_width="match_parent" android:layout_height="48dp" />

        <!-- ===== 模块1：标题与时间切换区 ===== -->
        <!-- 页面大标题 -->
        <TextView
            android:id="@+id/tv_stats_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="统计"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:layout_marginBottom="8dp" />

        <!-- 胶囊型时间切换栏 -->
        <LinearLayout
            android:id="@+id/ll_time_switcher"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_glass_card"
            android:padding="4dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_time_week"
                android:layout_width="56dp"
                android:layout_height="match_parent"
                android:text="周"
                android:textSize="14sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@android:color/transparent"
                android:textColor="@color/textSecondary" />

            <TextView
                android:id="@+id/tv_time_month"
                android:layout_width="56dp"
                android:layout_height="match_parent"
                android:text="月"
                android:textSize="14sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_budget_tip"
                android:textColor="@color/textPrimary" />

            <TextView
                android:id="@+id/tv_time_year"
                android:layout_width="56dp"
                android:layout_height="match_parent"
                android:text="年"
                android:textSize="14sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@android:color/transparent"
                android:textColor="@color/textSecondary" />
        </LinearLayout>

        <!-- 收支切换Tab -->
        <LinearLayout
            android:id="@+id/ll_type_tabs"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tv_type_expense"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="支出"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:textColor="@color/textPrimary"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/tv_type_income"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="收入"
                android:textSize="15sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:textColor="@color/textTertiary"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <!-- 选中指示线 -->
        <View
            android:id="@+id/v_type_indicator"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:background="@color/colorPrimary"
            android:layout_marginTop="-26dp"
            android:layout_marginBottom="24dp" />

        <!-- ===== 模块2：收支概览卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_overview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:outlineProvider="none"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <!-- 第一行：本月收入 + 本月支出 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="本月收入"
                            android:textSize="12sp"
                            android:textColor="@color/textTertiary" />

                        <TextView
                            android:id="@+id/tv_overview_income"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="¥0.00"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/income"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <View android:layout_width="20dp" android:layout_height="1dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="本月支出"
                            android:textSize="12sp"
                            android:textColor="@color/textTertiary" />

                        <TextView
                            android:id="@+id/tv_overview_expense"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="¥0.00"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/expense"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 第二行：本月结余 + 日均支出 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="本月结余"
                            android:textSize="12sp"
                            android:textColor="@color/textTertiary" />

                        <TextView
                            android:id="@+id/tv_overview_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="¥0.00"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <View android:layout_width="20dp" android:layout_height="1dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="日均支出"
                            android:textSize="12sp"
                            android:textColor="@color/textTertiary" />

                        <TextView
                            android:id="@+id/tv_overview_daily_avg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="¥0.00"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorPrimary"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== 模块3：收支趋势图卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_trend_chart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:outlineProvider="none"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="收支趋势"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/textSecondary"
                    android:layout_marginBottom="12dp" />

                <FrameLayout
                    android:id="@+id/fl_line_chart"
                    android:layout_width="match_parent"
                    android:layout_height="180dp">

                    <View
                        android:id="@+id/v_line_chart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </FrameLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== 模块4：分类占比与排行卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:outlineProvider="none"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/tv_category_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="支出分类"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/textSecondary"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/ll_category_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 左侧：环形甜甜圈图（40%宽度） -->
                    <FrameLayout
                        android:id="@+id/fl_donut_chart"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_weight="4">

                        <View
                            android:id="@+id/v_donut_chart"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </FrameLayout>

                    <!-- 右侧：分类排行（60%宽度） -->
                    <LinearLayout
                        android:id="@+id/ll_ranking"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="6"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:gravity="center_vertical"
                        android:paddingEnd="4dp">

                        <TextView
                            android:id="@+id/tv_no_category_data"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="暂无数据"
                            android:textSize="13sp"
                            android:textColor="@color/textTertiary"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_view_all_categories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="查看全部 >"
                    android:textSize="12sp"
                    android:textColor="@color/textTertiary"
                    android:gravity="end"
                    android:paddingTop="8dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 底部间距 -->
        <View android:layout_width="match_parent" android:layout_height="100dp" />

    </LinearLayout>
</ScrollView>